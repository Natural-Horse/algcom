# Ignore everything by default
*

# Keep directories so we can unignore files inside them
!*/

# Keep this .gitignore tracked
!.gitignore

# Allow common source code files (recursively)
!**/*.c
!**/*.cc
!**/*.cpp
!**/*.cxx
!**/*.h
!**/*.hh
!**/*.hpp
!**/*.py
!**/*.java
!**/*.kt
!**/*.kts
!**/*.go
!**/*.rs
!**/*.m
!**/*.mm
!**/*.js
!**/*.ts
!**/*.jsx
!**/*.tsx
!**/*.cs
!**/*.php
!**/*.rb
!**/*.pl
!**/*.sh
!**/*.bash
!**/*.ps1
!**/*.scala
!**/*.lua
!**/*.swift

# Allow common build/source files if you prefer (optional)
!**/Makefile

# End of .gitignore
# Compiled Object files
*.o
*.obj

# Compiled Binary files (Linux/Mac)
*.out
*.app
*.exe
# Ignore specifically named binaries if possible, or build folders
build/
bin/
Debug/
Release/

# VS Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db

# Try to match likely binary files (no extension) in specific folders if known, or just rely on user manually not adding them
# Unfortunately git doesn't have a "no extension" selector easily

# Re-ignore everything inside specific known build output folders if they exist
*/build/*
*/bin/*
